# Agent Org Network — 로컬 개발 환경 변수 (예시)
#
# 사용:  cp .env.example .env   ( .env 는 .gitignore — 절대 커밋되지 않는다 )
# scripts/run_web.sh 가 이 .env 를 읽어 uvicorn 에 넘긴다. 보통은 그냥 `scripts/run_web.sh` 만
# 실행하면 된다 — OPERATOR_SESSION_SECRET 이 비어 있으면 스크립트가 한 번 생성해 .env 에
# 보존하므로, 이 항목은 비워 둬도 로그인이 동작한다.

# ── 운영 면 세션 서명 키 (T6.5·ADR 0016) ────────────────────────────────────
# 처리함·큐·모니터링·그래프·빌더 + 프론트 /inbox·/console 의 세션 로그인 서명 키.
# 미설정이면 인증이 OFF → POST /login 이 500, 운영 라우트가 401("세션 미들웨어 미부착").
# 직접 채우려면:  openssl rand -hex 32
# (이 파일은 커밋되므로 실 비밀을 여기 적지 말 것 — 진짜 키는 gitignored .env 에만 둔다.)
OPERATOR_SESSION_SECRET=

# ── 분류기 (선택) ───────────────────────────────────────────────────────────
# 비우면 키워드 규칙(RuleBasedClassifier — 빠름·결정론). llm 이면 실 claude(Haiku) 분류.
# AON_CLASSIFIER=llm

# ── 답 생성 런타임 (선택) ───────────────────────────────────────────────────
# 비우면 ClaudeCodeRuntime(`claude -p`). claude-api / codex 선택 가능
# (scripts/run_worker.sh 상단 주석 참고 — 전제·extra 설치 안내).
# AON_PROVIDER=claude-api
