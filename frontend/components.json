{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "default",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "app/globals.css",
    "baseColor": "slate",
    "cssVariables": true,
    "prefix": ""
  },
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "hooks": "@/hooks",
    "lib": "@/lib"
  },
  "x-design-ontology": {
    "preset": "dashboard--corporate-trust",
    "adapter": "nextjs-tailwind-shadcn@0.1.0",
    "color_modes": [
      "light",
      "dark"
    ],
    "locale_pairings": []
  }
}
